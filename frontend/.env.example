# URL do backend usada pelo frontend.
# Quando não definida, o frontend deriva automaticamente a URL a partir do
# endereço atual do navegador (mesmo host, porta 8000). Isso funciona tanto
# em localhost quanto ao acessar de outro dispositivo na rede (ex: celular).
# Defina esta variável somente se o backend estiver em um host/porta diferente.
# Exemplo: VITE_BACKEND_URL=https://192.168.1.100:8000
# VITE_BACKEND_URL=
